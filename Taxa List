<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Taxa Reference List</title>
    <style>
        :root {
            --primary-color: #2c3e50;
            --secondary-color: #555555;
            --light-border: #dcdde1;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            color: #222;
            line-height: 1.3;
            margin: 0;
            padding: 20px;
            font-size: 10.5pt;
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
        }

        header {
            text-align: center;
            border-bottom: 2px solid var(--primary-color);
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        header h1 {
            margin: 0;
            font-size: 22pt;
            color: var(--primary-color);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        header p {
            margin: 5px 0 0 0;
            font-size: 10pt;
            color: #666;
        }

        .kingdom-section {
            margin-top: 20px;
            page-break-inside: initial;
        }

        .kingdom-title {
            font-size: 14pt;
            color: #fff;
            background-color: var(--primary-color);
            padding: 4px 10px;
            margin: 15px 0 10px 0;
            text-transform: uppercase;
            font-weight: bold;
            letter-spacing: 0.5px;
        }

        .phylum-section {
            margin-left: 5px;
            margin-bottom: 10px;
        }

        .phylum-title {
            font-size: 12pt;
            color: var(--primary-color);
            border-bottom: 1.5px solid var(--primary-color);
            padding-bottom: 2px;
            margin: 12px 0 6px 0;
            font-weight: bold;
        }

        .class-section {
            margin-left: 10px;
            margin-bottom: 15px;
        }

        .class-title {
            color: #444;
            font-weight: bold;
            margin: 8px 0 4px 0;
            text-transform: uppercase;
            font-size: 9.5pt;
            letter-spacing: 0.3px;
            border-left: 3px solid #7f8c8d;
            padding-left: 6px;
        }

        /* Compact multi-column grid layout for desktop screen views */
        .taxa-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 6px;
            margin-left: 5px;
        }

        .taxa-item {
            border: 1px solid var(--light-border);
            padding: 5px 8px;
            background-color: #fafafa;
            page-break-inside: avoid;
            border-radius: 2px;
        }

        .taxa-main {
            font-size: 10pt;
            margin-bottom: 2px;
        }

        .scientific-name {
            font-style: italic;
            font-weight: 700;
            color: #000;
        }

        .common-name {
            color: #333;
            margin-left: 4px;
        }

        .common-name::before {
            content: " — ";
            color: #888;
        }

        .taxa-details {
            font-size: 8.5pt;
            color: var(--secondary-color);
        }

        .obs-year {
            font-weight: 600;
        }

        .obs-type::before {
            content: " • ";
            color: #aaa;
        }

        /* Physical Paper Print Formatting rules */
        @media print {
            body {
                padding: 0;
                font-size: 9.5pt;
            }
            .container {
                max-width: 100%;
            }
            .taxa-item {
                border: 1px solid #ccc;
                background-color: #fff;
            }
            .kingdom-title {
                background-color: #2c3e50 !important;
                color: #fff !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
            h1, h2, h3, .kingdom-title, .phylum-title, .class-title {
                page-break-after: avoid;
            }
            .taxa-grid {
                display: grid;
                grid-template-columns: 1fr 1fr; /* Forces exactly 2 dense text columns on print sheets */
            }
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>Taxa Reference List</h1>
        <p>Total Records: 2378 • Sorted Hierarchically</p>
    </header>

    <div class="kingdom-section">
        <div class="kingdom-title">Kingdom: Animalia</div>
        <div class="phylum-section">
            <div class="phylum-title">Phylum: Annelida</div>
            <div class="class-section">
                <div class="class-title">Class: Clitellata</div>
                <div class="taxa-grid">
                    <div class="taxa-item">
                        <div class="taxa-main"><span class="scientific-name">Lumbricus terrestris</span><span class="common-name">Nightcrawler</span></div>
                        <div class="taxa-details"><span class="obs-year">2024</span><span class="obs-type">iNat Observation</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>
